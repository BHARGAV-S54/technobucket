{
  "version": 2,
  "builds": [
    {
      "src": "technobucket/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "pythonVersion": "3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "technobucket/wsgi.py"
    }
  ],
  "buildCommand": "python manage.py collectstatic --noinput"
}
