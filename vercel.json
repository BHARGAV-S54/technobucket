{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "outputDirectory": "./staticfiles",
  "builds": [
    {
      "src": "technobucket/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "technobucket/wsgi.py"
    }
  ],
  "functions": {
    "technobucket/wsgi.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "env": {
    "STATIC_URL": "/static/",
    "STATIC_ROOT": "staticfiles",
    "DEBUG": "False"
  }
}
